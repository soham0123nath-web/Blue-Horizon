# ══════════════════════════════════════════════════
# Blue Horizon Overseas — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════

# ── Supabase (Required) ──
# Create a new project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Chatbot (Optional — enables AI chatbot + admin assistant) ──
# Uses Groq API for the public chatbot and admin assistant
GROQ_API_KEY=your-groq-api-key-here

# ── OpenAI (Optional — enables AI salary advisor) ──
OPENAI_API_KEY=sk-your-openai-key-here

# ── Resend (Optional — enables transactional emails) ──
RESEND_API_KEY=re_your-resend-api-key-here

# ── Super Admin (Required for admin dashboard) ──
# This email gets automatic superadmin access without needing bh_admins entry
SUPER_ADMIN_EMAIL=your-email@example.com

# ── Environment ──
NODE_ENV=production
